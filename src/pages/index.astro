---
import Layout from "../components/Layout.astro";
import { Image, Picture } from '@astrojs/image/components';

const response = await fetch("https://cms.dailybyte.org/graphql", {
  method: 'POST',
  headers: {'Content-Type':'application/json'},
  body: JSON.stringify({
    query: `
      query GET_ALL_POSTS {
    posts {
      nodes {
        id
        slug
        title
        date
        content
        excerpt
        featuredImage {
          node {
            sourceUrl
          }
        }
      }
    }
  }
    `
  })
})

const json = await response.json()
const data = json.data.posts.nodes
console.log(data[0].featuredImage.node.sourceUrl)
---

  <Layout>
    {data.map((post) => {
      return (
        <h2>{post.title}</h2>
        <img
          src={post.featuredImage.node.sourceUrl}
          width={500}
          height={500}
        />
        <p>{post.content}</p>
      )
    })}
  </Layout>