---
import Layout from "../components/Layout.astro";
import { Image, Picture } from '@astrojs/image/components';

const response = await fetch("https://cms.dailybyte.org/graphql", {
  method: 'POST',
  headers: {'Content-Type':'application/json'},
  body: JSON.stringify({
    query: `
      query GET_ALL_POSTS {
    posts {
      nodes {
        id
        slug
        title
        date
        content
        excerpt
        featuredImage {
          node {
            sourceUrl
          }
        }
      }
    }
  }
    `
  })
})

const json = await response.json()
const data = json.data.posts.nodes
console.log(data[0].featuredImage.node.sourceUrl)
---
<style>
  h2 {
    text-align: center;
    margin: 60px 0;
  }
  .doc {
    font-family: Roboto;
  }
  #card {
    width: 80%;
    margin: 0 auto;
    margin-bottom: 25px;
    background-color: lightgrey;
    border-radius: 20px;
    padding: 10px 20px;
    transition: all .2s ease-in-out;
  }
  #card:hover {
    transform: scale(1.013);
  }
</style>

  <Layout>
    <div class="doc">
      <h2>All Sharks</h2>
    {data.map((post) => {
      return (
        <div id="card">
        <h3 class="red">{post.title}</h3>
        <img
          src={post.featuredImage.node.sourceUrl}
          width={250}
          height={250}
        />
        <div set:html={post.content} />
        </div>
      )
    })}
    </div>
  </Layout>